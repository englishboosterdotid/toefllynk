// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============ ENUMS ============

enum Role {
  USER
  ADMIN
}

enum SellerTier {
  FREE
  STARTER
  PRO
  BUSINESS
}

enum Category {
  IELTS
  TOEFL
  TOEIC
}

enum ProductType {
  TOEFL_SIMULATION
  IELTS_SIMULATION
}

enum PackageType {
  INDIVIDUAL
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum Section {
  LISTENING
  STRUCTURE
  READING
}

enum SessionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum AdminPlatformFeeStatus {
  ACTIVE
  VOIDED
}

enum ActivityType {
  TAB_SWITCH
  FULLSCREEN_EXIT
  FULLSCREEN_ENTER
  SECTION_CHANGE
  AUTO_SUBMIT
  MANUAL_SUBMIT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  VIEW
  EXPORT
}

enum PromoType {
  PERCENTAGE
  FIXED
}

enum PromoStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  USED_UP
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ============ CORE MODELS ============

model User {
  id       String  @id @default(cuid())
  name     String?
  email    String  @unique
  password String
  username String  @unique
  avatar   String?
  role     Role    @default(USER)

  // Email verification
  emailVerified        Boolean   @default(false)
  emailVerificationToken String? @unique
  emailVerificationSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  products          Product[]
  affiliateLinks     AffiliateEnrollment[] @relation("AffiliateUser")
  ownedProducts     AffiliateEnrollment[] @relation("OwnerUser")
  ownedStudents     StudentAccount[]      @relation("OwnedStudents")
  studentProfile    StudentAccount?       @relation("StudentUpgradeUser")
  affiliateEarnings AffiliateConversion[] @relation("AffiliateIncomeUser")
  salesEarnings     AffiliateConversion[] @relation("AffiliateOwnerUser")
  auditLogs         AdminAuditLog[]
  withdrawals       WithdrawalRequest[]
  processedWithdrawals WithdrawalRequest[] @relation("WithdrawalProcessor")
  tierLogs          SellerTierLog[]
  certificateTemplate CertificateTemplate?
  promoCodes        PromoCode[]
  micrositeSettings MicrositeSettings?
  apiKey            ApiKey?
  webhookEndpoints  WebhookEndpoint[]
  customers         Customer[]
  emailCampaigns    EmailCampaign[]
  supportTickets    SupportTicket[]
  micrositeViews    MicrositeView[]

  // 1:1 relations (normalized)
  profile     SellerProfile?
  bankAccount BankAccount?
}

model SellerProfile {
  id              String      @id @default(cuid())
  userId          String      @unique
  bio             String?
  headline        String?
  ctaText         String?
  whatsapp        String?

  // Seller tier system
  sellerTier          SellerTier  @default(FREE)
  subscriptionStart   DateTime?
  subscriptionEnd     DateTime?
  customFeeRate       Int?        // Override fee rate (0-20)
  tierChangedAt        DateTime?
  tierChangeReason    String?

  // Custom domain (BUSINESS only)
  customDomain        String?
  domainVerified      Boolean     @default(false)
  domainVerifiedAt    DateTime?

  // Cached balance (updated after each transaction)
  balance              Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BankAccount {
  id           String  @id @default(cuid())
  userId       String  @unique
  bankName     String?
  bankAccount  String?
  bankHolder   String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ PRODUCT MODELS ============

model Product {
  id          String      @id @default(cuid())
  userId      String
  title       String
  description String?
  price       Int
  thumbnail   String?
  category    String?
  productType ProductType @default(TOEFL_SIMULATION)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relations
  affiliateEnrollments AffiliateEnrollment[]
  orders               Order[]
  studentCredits        StudentExamCredit[]
  examResults           ExamResult[]
  affiliateClicks      AffiliateClick[]
  productViews          ProductView[]

  // 1:1 relation for product settings
  settings ProductSettings?

  @@index([userId])
  @@index([category])
  @@index([productType])
}

model ProductSettings {
  id                  String       @id @default(cuid())
  productId           String       @unique

  promoPrice          Int?
  checkoutLink        String?
  packageType         PackageType?
  examCredits         Int          @default(1)
  certificateIncluded Boolean      @default(true)
  reviewIncluded      Boolean      @default(false)
  zoomIncluded        Boolean      @default(false)
  affiliateEnabled    Boolean      @default(false)
  affiliateCommission Int          @default(10)
  isArchived          Boolean      @default(false)
  isVisibleOnMicrosite Boolean    @default(true)
  isFeatured          Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ============ AFFILIATE MODELS ============

model AffiliateEnrollment {
  id                String   @id @default(cuid())
  affiliateUserId   String
  ownerUserId       String
  productId         String
  referralCode      String   @unique
  commissionPercent Int      @default(10)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  affiliateUser User    @relation("AffiliateUser", fields: [affiliateUserId], references: [id], onDelete: Cascade)
  ownerUser      User    @relation("OwnerUser", fields: [ownerUserId], references: [id], onDelete: Cascade)
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([affiliateUserId])
  @@index([ownerUserId])
  @@index([productId])
}

model AffiliateClick {
  id           String   @id @default(cuid())
  referralCode String
  productId    String
  visitorIp    String?
  clickedAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([referralCode])
  @@index([clickedAt])
  @@index([productId])
}

model AffiliateConversion {
  id               String   @id @default(cuid())
  referralCode     String
  orderId          String   @unique
  affiliateUserId  String
  ownerUserId      String
  commissionAmount Int
  createdAt        DateTime @default(now())

  order          Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  affiliateUser  User  @relation("AffiliateIncomeUser", fields: [affiliateUserId], references: [id], onDelete: Cascade)
  ownerUser      User  @relation("AffiliateOwnerUser", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([affiliateUserId])
  @@index([ownerUserId])
  @@index([referralCode])
  @@index([createdAt])
}

// ============ ORDER MODELS ============

model Order {
  id            String      @id @default(cuid())
  productId     String
  buyerName     String
  buyerEmail    String
  buyerWhatsapp String?
  referralCode  String?
  status        OrderStatus @default(PENDING)
  studentId     String?
  customerId    String?
  createdAt     DateTime    @default(now())

  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  student StudentAccount? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  customer Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)

  affiliateConversion AffiliateConversion?
  adminFee            AdminPlatformFee?

  @@index([status])
  @@index([createdAt])
  @@index([productId])
  @@index([referralCode])
  @@index([customerId])
  @@index([buyerEmail])
  @@index([productId, status])
}

model AdminPlatformFee {
  id        String   @id @default(cuid())
  orderId   String   @unique
  feeAmount Int
  status    AdminPlatformFeeStatus @default(ACTIVE)
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ============ WITHDRAWAL MODELS ============

model WithdrawalRequest {
  id          String           @id @default(cuid())
  userId      String
  amount      Int              // Amount requested (before fee)
  feeAmount   Int?
  netAmount   Int?             // Amount user will receive (amount - fee)
  bankName    String
  bankAccount String
  bankHolder  String
  status      WithdrawalStatus @default(PENDING)
  notes       String?
  processedAt DateTime?
  processedBy String?
  createdAt   DateTime         @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin  User?  @relation("WithdrawalProcessor", fields: [processedBy], references: [id], onDelete: SetNull)

  transactions WithdrawalTransaction[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model WithdrawalTransaction {
  id            String   @id @default(cuid())
  withdrawalId  String
  type          String   // EARNING, WITHDRAWAL, ADJUSTMENT
  amount        Int
  description   String?
  balanceAfter  Int
  createdAt     DateTime @default(now())

  withdrawal WithdrawalRequest @relation(fields: [withdrawalId], references: [id], onDelete: Cascade)

  @@index([withdrawalId])
}

// ============ STUDENT MODELS ============

model StudentAccount {
  id             String   @id @default(cuid())
  buyerName      String
  buyerEmail     String   @unique
  buyerWhatsapp  String?
  accessToken    String   @unique
  ownerUserId    String
  userId         String?  @unique  // If student upgrades to seller account
  totalPurchased Int     @default(0)
  isConverted     Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ownerUser User  @relation("OwnedStudents", fields: [ownerUserId], references: [id], onDelete: Cascade)
  user      User? @relation("StudentUpgradeUser", fields: [userId], references: [id], onDelete: Cascade)

  credits  StudentExamCredit[]
  results  ExamResult[]
  sessions ExamSession[]
  orders   Order[]
}

model StudentExamCredit {
  id          String   @id @default(cuid())
  studentId   String
  totalCredit Int
  usedCredit  Int      @default(0)
  productId   String
  createdAt   DateTime @default(now())

  student StudentAccount @relation(fields: [studentId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([productId])
}

// ============ EXAM MODELS ============

model ExamResult {
  id                String   @id @default(cuid())
  studentId         String
  listeningCorrect  Int
  structureCorrect  Int
  readingCorrect    Int
  totalScore        Int
  productId         String
  createdAt         DateTime @default(now())

  student StudentAccount @relation(fields: [studentId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([productId])
  @@index([createdAt])
  @@index([totalScore])
}

model ExamSession {
  id               String         @id @default(cuid())
  studentId        String
  status           SessionStatus  @default(NOT_STARTED)
  currentSection   String?
  sectionTimeLeft  Int            @default(0)
  totalElapsedTime Int            @default(0)
  startedAt        DateTime?
  completedAt      DateTime?
  lastActivity     DateTime?
  progress         Json?
  createdAt        DateTime       @default(now())

  student      StudentAccount  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers      ExamAnswer[]
  activityLogs ExamActivityLog[]

  @@index([studentId])
  @@index([status])
  @@index([lastActivity])
}

model ExamActivityLog {
  id           String       @id @default(cuid())
  sessionId    String
  activityType ActivityType
  details      Json?
  createdAt    DateTime     @default(now())

  session ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([activityType])
  @@index([createdAt])
}

model ExamAnswer {
  id          String   @id @default(cuid())
  sessionId   String
  questionId  String
  selectedKey String
  isFlagged   Boolean  @default(false)
  timeSpent   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session  ExamSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question QuestionBank @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
  @@index([sessionId])
}

// ============ QUESTION MODELS ============

model QuestionBank {
  id             String   @id @default(cuid())
  section        Section
  questionNumber Int
  questionText   String
  passageText    String?
  audioUrl       String?
  correctAnswer  String
  explanation    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  options     QuestionOption[]
  examAnswers ExamAnswer[]

  @@index([section])
}

model QuestionOption {
  id         String @id @default(cuid())
  questionId String
  optionKey  String
  optionText String

  question QuestionBank @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, optionKey])
}

// ============ ADMIN MODELS ============

model AdminAuditLog {
  id          String      @id @default(cuid())
  adminId     String
  action      AuditAction
  entityType  String
  entityId    String?
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  details     String?
  createdAt   DateTime    @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([entityType])
  @@index([action])
  @@index([createdAt])
}

model SellerTierLog {
  id        String     @id @default(cuid())
  userId    String
  oldTier   SellerTier?
  newTier   SellerTier
  changedBy String     // "ADMIN", "SYSTEM", or userId
  reason    String?
  feeOverride Int?
  createdAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// ============ SUBSCRIPTION MODELS ============

model Subscription {
  id            String      @id @default(cuid())
  userId        String      @unique
  tier          SellerTier
  transactionId String?
  amount        Int
  status        String      @default("PENDING")
  startedAt     DateTime?
  expiresAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@index([transactionId])
}

model SubscriptionPlan {
  id         String     @id @default(cuid())
  tier       SellerTier @unique
  name       String
  price      Int
  periodDays Int        @default(30)
  isActive   Boolean    @default(true)
  features   Json
  createdAt  DateTime   @default(now())

  @@index([tier])
}

// ============ CUSTOMIZATION MODELS ============

model CertificateTemplate {
  id              String   @id @default(cuid())
  userId          String   @unique
  name            String   @default("Custom Template")
  title           String   @default("TOEFL ITP Simulation")
  subtitle        String   @default("Certificate of Completion")
  showLogo        Boolean  @default(true)
  logoUrl         String?
  signatureText   String   @default("Authorized Signature")
  footerText      String?
  validityDays    Int?     @default(365)
  backgroundImage String?
  fontFamily      String   @default("Inter")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MicrositeSettings {
  id                  String   @id @default(cuid())
  userId              String   @unique
  customHeaderHtml    String?
  showDefaultHeader   Boolean  @default(true)
  customFooterHtml    String?
  showDefaultFooter   Boolean  @default(true)
  footerText          String?
  removeLynkLogo      Boolean  @default(false)
  showPoweredBy       Boolean  @default(true)
  themeMode           String   @default("light")
  primaryColor        String   @default("#3b82f6")
  secondaryColor      String?
  accentColor         String?
  fontFamily          String   @default("Inter")
  customCss           String?
  socialInstagram     String?
  socialFacebook      String?
  socialTwitter       String?
  socialYoutube       String?
  socialTiktok        String?
  socialLinkedin      String?
  contactEmail        String?
  contactPhone        String?
  contactAddress      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============ PROMO MODELS ============

model PromoCode {
  id            String      @id @default(cuid())
  userId        String
  code          String      @unique
  type          PromoType   @default(PERCENTAGE)
  value         Int
  minPurchase   Int         @default(0)
  maxDiscount   Int?
  usageLimit    Int?
  usageCount    Int         @default(0)
  startDate     DateTime    @default(now())
  endDate       DateTime?
  status        PromoStatus @default(ACTIVE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  redemptions PromoRedemption[]

  @@index([userId])
  @@index([code])
  @@index([status])
}

model PromoRedemption {
  id       String    @id @default(cuid())
  promoId  String
  orderId  String
  userId   String
  discount Int
  usedAt   DateTime  @default(now())

  promo PromoCode @relation(fields: [promoId], references: [id], onDelete: Cascade)

  @@index([promoId])
  @@index([userId])
}

// ============ CRM MODELS ============

model Customer {
  id             String    @id @default(cuid())
  ownerUserId    String
  buyerName      String
  buyerEmail     String    @unique
  buyerPhone     String?
  buyerAddress   String?
  totalPurchases Int      @default(0)
  totalSpent     Int       @default(0)
  lastPurchaseAt DateTime?
  notes          String?
  tags           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  ownerUser User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@index([ownerUserId])
  @@index([buyerEmail])
  @@index([createdAt])
  @@index([ownerUserId, createdAt])
}

// ============ API & WEBHOOK MODELS ============

model ApiKey {
  id          String    @id @default(cuid())
  userId      String    @unique
  key         String    @unique
  keyPrefix   String
  name        String
  permissions Json
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([key])
}

model WebhookEndpoint {
  id            String    @id @default(cuid())
  userId        String
  url           String
  events        Json
  secret        String?
  isActive      Boolean   @default(true)
  lastTriggered DateTime?
  failureCount  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([userId])
  @@index([isActive])
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  webhookId   String
  event       String
  payload     Json
  response    Json?
  statusCode  Int?
  success     Boolean  @default(false)
  error       String?
  deliveredAt DateTime @default(now())

  webhook WebhookEndpoint @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([deliveredAt])
}

// ============ ANALYTICS MODELS ============

model ProductView {
  id          String   @id @default(cuid())
  productId   String
  viewerIp    String?
  userAgent   String?
  referrer    String?
  viewedAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([viewedAt])
}

model MicrositeView {
  id          String   @id @default(cuid())
  userId      String
  viewerIp    String?
  userAgent   String?
  referrer    String?
  viewedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([viewedAt])
}

model EmailCampaign {
  id              String    @id @default(cuid())
  userId          String
  name            String
  subject         String
  template        String?
  sentCount       Int       @default(0)
  deliveredCount  Int       @default(0)
  openCount       Int       @default(0)
  clickCount      Int       @default(0)
  status          String    @default("DRAFT")
  scheduledAt     DateTime?
  sentAt          DateTime?
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([sentAt])
}

// ============ SUPPORT MODELS ============

model SupportTicket {
  id              String           @id @default(cuid())
  userId          String
  subject         String
  message         String
  responseMessage String?
  status          TicketStatus     @default(OPEN)
  priority        TicketPriority   @default(NORMAL)
  category        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([category])
}
