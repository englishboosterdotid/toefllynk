// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============ ENUMS ============

enum Role {
  USER
  ADMIN
}

enum SellerTier {
  FREE    // 10% platform fee, 1 product max
  BASIC   // 8% platform fee, 5 products
  PRO     // 5% platform fee, unlimited products
  BUSINESS // 3% platform fee, unlimited + white-label
}

enum Category {
  IELTS
  TOEFL
  TOEIC
}

enum ProductType {
  TOEFL_SIMULATION
  IELTS_SIMULATION
  COURSE
  BUNDLE
}

enum PackageType {
  INDIVIDUAL
  BUNDLE
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum Section {
  LISTENING
  STRUCTURE
  READING
}

// ============ MODELS ============

model User {
  id       String  @id @default(cuid())
  name     String?
  email    String  @unique
  password String
  username String  @unique

  bio      String?
  whatsapp String?
  avatar   String?
  headline String?
  ctaText  String?
  role     Role    @default(USER)

  // Seller tier system
  sellerTier        SellerTier  @default(FREE)
  subscriptionStart DateTime?
  subscriptionEnd  DateTime?
  customFeeRate    Int?         // Override fee rate (0-20), null = use tier default
  tierChangedAt    DateTime?
  tierChangeReason String?

  // Custom domain (BUSINESS only)
  customDomain     String?
  domainVerified    Boolean     @default(false)
  domainVerifiedAt DateTime?

  // Bank info for withdrawals
  bankName    String?
  bankAccount String?
  bankHolder  String?

  createdAt DateTime @default(now())

  products Product[]

  affiliateLinks         AffiliateEnrollment[] @relation("AffiliateUser")
  ownedAffiliateProducts AffiliateEnrollment[] @relation("OwnerUser")
  ownedStudents          StudentAccount[]      @relation("OwnedStudents")
  studentProfile         StudentAccount?       @relation("StudentUpgradeUser")
  affiliateConversions   AffiliateConversion[] @relation("AffiliateIncomeUser")
  ownedConversions       AffiliateConversion[] @relation("AffiliateOwnerUser")
  auditLogs             AdminAuditLog[]
  withdrawalRequests    WithdrawalRequest[]
  processedWithdrawals  WithdrawalRequest[]   @relation("WithdrawalProcessor")
  tierLogs             SellerTierLog[]
  certificateTemplate  CertificateTemplate?
  promoCodes          PromoCode[]
  micrositeSettings  MicrositeSettings?
  apiKey            ApiKey?
  webhookEndpoints  WebhookEndpoint[]
  customers         Customer[]
  emailCampaigns    EmailCampaign[]
  supportTickets    SupportTicket[]
}

model Product {
  id                  String      @id @default(cuid())
  userId              String
  title               String
  description         String?
  price               Int
  promoPrice          Int?
  thumbnail           String?
  checkoutLink        String?
  category            String?
  productType         ProductType @default(TOEFL_SIMULATION)
  packageType         PackageType?
  examCredits         Int         @default(1)
  certificateIncluded Boolean     @default(true)
  reviewIncluded      Boolean     @default(false)
  zoomIncluded        Boolean     @default(false)
  affiliateEnabled    Boolean     @default(false)
  affiliateCommission Int         @default(10)
  isArchived          Boolean     @default(false)
  isVisibleOnMicrosite Boolean    @default(true)
  isFeatured         Boolean     @default(false) // PRO+ can set featured products
  createdAt           DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  affiliateEnrollments AffiliateEnrollment[]
  orders               Order[]
  studentCredits       StudentExamCredit[]
  examResults          ExamResult[]
  affiliateClicks      AffiliateClick[]
  productViews         ProductView[]

  @@index([userId])
  @@index([category])
  @@index([productType])
  @@index([isArchived])
  @@index([isVisibleOnMicrosite])
}

model AffiliateEnrollment {
  id                String   @id @default(cuid())
  affiliateUserId   String
  ownerUserId       String
  productId         String
  referralCode      String   @unique
  commissionPercent Int      @default(10)
  createdAt         DateTime @default(now())

  affiliateUser User    @relation("AffiliateUser", fields: [affiliateUserId], references: [id], onDelete: Cascade)
  ownerUser     User    @relation("OwnerUser", fields: [ownerUserId], references: [id], onDelete: Cascade)
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([affiliateUserId])
  @@index([ownerUserId])
  @@index([productId])
}

model AffiliateClick {
  id           String   @id @default(cuid())
  referralCode String
  productId    String
  visitorIp    String?
  clickedAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([referralCode])
  @@index([clickedAt])
  @@index([productId])
}

model Order {
  id            String      @id @default(cuid())
  productId     String
  buyerName     String
  buyerEmail    String
  buyerWhatsapp String?
  referralCode  String?
  status        OrderStatus @default(PENDING)
  studentId     String?
  createdAt     DateTime    @default(now())

  affiliateConversion AffiliateConversion?
  adminFee            AdminPlatformFee?

  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  student StudentAccount? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  customer Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerId String?

  @@index([status])
  @@index([createdAt])
  @@index([productId])
  @@index([referralCode])
  @@index([customerId])
  @@index([buyerEmail])
  @@index([productId, status])
}

model AffiliateConversion {
  id               String   @id @default(cuid())
  referralCode     String
  orderId          String   @unique
  affiliateUserId  String
  ownerUserId      String
  commissionAmount Int
  createdAt        DateTime @default(now())

  order         Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  affiliateUser User  @relation("AffiliateIncomeUser", fields: [affiliateUserId], references: [id], onDelete: Cascade)
  ownerUser     User  @relation("AffiliateOwnerUser", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([affiliateUserId])
  @@index([ownerUserId])
  @@index([referralCode])
  @@index([createdAt])
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum AdminPlatformFeeStatus {
  ACTIVE
  VOIDED
}

model AdminPlatformFee {
  id        String   @id @default(cuid())
  orderId   String   @unique
  feeAmount Int
  status    AdminPlatformFeeStatus @default(ACTIVE)
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model WithdrawalRequest {
  id          String           @id @default(cuid())
  userId      String
  amount      Int              // Amount requested (before fee)
  feeAmount   Int?             // Withdrawal fee (1%)
  netAmount   Int?              // Amount user will receive (amount - fee)
  bankName    String
  bankAccount String
  bankHolder  String
  status      WithdrawalStatus @default(PENDING)
  notes       String?
  processedAt DateTime?
  processedBy String?
  createdAt   DateTime         @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin  User?  @relation("WithdrawalProcessor", fields: [processedBy], references: [id], onDelete: SetNull)

  transactions WithdrawalTransaction[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model WithdrawalTransaction {
  id            String   @id @default(cuid())
  withdrawalId  String
  type          String   // EARNING, WITHDRAWAL, ADJUSTMENT
  amount        Int
  description   String?
  balanceAfter  Int
  createdAt     DateTime @default(now())

  withdrawal WithdrawalRequest @relation(fields: [withdrawalId], references: [id], onDelete: Cascade)

  @@index([withdrawalId])
}

model StudentAccount {
  id            String   @id @default(cuid())
  buyerName     String
  buyerEmail    String   @unique
  buyerWhatsapp String?
  accessToken   String   @unique
  ownerUserId   String
  userId        String?  @unique
  createdAt     DateTime @default(now())

  ownerUser User  @relation("OwnedStudents", fields: [ownerUserId], references: [id], onDelete: Cascade)
  user      User? @relation("StudentUpgradeUser", fields: [userId], references: [id], onDelete: Cascade)

  credits        StudentExamCredit[]
  results        ExamResult[]
  sessions       ExamSession[]
  orders         Order[]
}

model StudentExamCredit {
  id          String   @id @default(cuid())
  studentId   String
  totalCredit Int
  usedCredit  Int      @default(0)
  productId   String
  createdAt   DateTime @default(now())

  student StudentAccount @relation(fields: [studentId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([productId])
}

model ExamResult {
  id               String   @id @default(cuid())
  studentId        String
  listeningCorrect Int
  structureCorrect Int
  readingCorrect   Int
  totalScore       Int
  productId        String
  createdAt        DateTime @default(now())

  student StudentAccount @relation(fields: [studentId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([productId])
  @@index([createdAt])
  @@index([totalScore])
}

model QuestionBank {
  id             String   @id @default(cuid())
  section        Section
  questionNumber Int
  questionText   String
  passageText    String?
  audioUrl       String?
  correctAnswer  String
  explanation    String?
  createdAt      DateTime @default(now())

  options        QuestionOption[]
  examAnswers    ExamAnswer[]

  @@index([section])
}

model QuestionOption {
  id         String @id @default(cuid())
  questionId String
  optionKey  String // A B C D
  optionText String

  question QuestionBank @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, optionKey])
}

enum SessionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model ExamSession {
  id               String         @id @default(cuid())
  studentId        String
  status           SessionStatus  @default(NOT_STARTED)
  currentSection   String?        // LISTENING, STRUCTURE, READING
  sectionTimeLeft  Int            @default(0) // seconds left for current section
  totalElapsedTime Int            @default(0) // total seconds elapsed
  startedAt       DateTime?
  completedAt     DateTime?
  lastActivity     DateTime?
  progress         Json?          // stores { answers: {}, flaggedQuestions: [], currentQuestion: number }
  createdAt       DateTime       @default(now())

  student  StudentAccount @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers  ExamAnswer[]
  activityLogs ExamActivityLog[]

  @@index([studentId])
  @@index([status])
  @@index([lastActivity])
}

enum ActivityType {
  TAB_SWITCH
  FULLSCREEN_EXIT
  FULLSCREEN_ENTER
  SECTION_CHANGE
  AUTO_SUBMIT
  MANUAL_SUBMIT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  VIEW
  EXPORT
}

model AdminAuditLog {
  id          String      @id @default(cuid())
  adminId     String
  action      AuditAction
  entityType  String      // e.g., "QuestionBank", "Product", "Order"
  entityId    String?
  oldValue    Json?       // For UPDATE/DELETE
  newValue    Json?       // For CREATE/UPDATE
  ipAddress   String?
  userAgent   String?
  details     String?     // Additional description
  createdAt   DateTime    @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([entityType])
  @@index([action])
  @@index([createdAt])
}

model ExamActivityLog {
  id          String       @id @default(cuid())
  sessionId   String
  activityType ActivityType
  details     Json?        // additional data like warning count, section, etc.
  createdAt   DateTime     @default(now())

  session ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([activityType])
  @@index([createdAt])
}

model ExamAnswer {
  id          String   @id @default(cuid())
  sessionId   String
  questionId  String
  selectedKey String
  isFlagged   Boolean  @default(false)
  timeSpent   Int      @default(0) // seconds spent on this question
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session   ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question  QuestionBank @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
  @@index([sessionId])
}

model SellerTierLog {
  id          String     @id @default(cuid())
  userId      String
  oldTier     SellerTier?
  newTier     SellerTier
  changedBy   String     // "ADMIN", "SYSTEM", or userId for self-upgrade
  reason      String?
  feeOverride Int?
  createdAt   DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Subscription {
  id                String      @id @default(cuid())
  userId            String      @unique
  tier              SellerTier
  transactionId     String?     // Midtrans transaction ID
  amount            Int         // in Rupiah
  status            String      @default("PENDING") // PENDING, ACTIVE, EXPIRED, CANCELLED
  startedAt         DateTime?
  expiresAt         DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@index([transactionId])
}

model SubscriptionPlan {
  id          String     @id @default(cuid())
  tier        SellerTier @unique
  name        String     // Display name (e.g., "Mulai", "Berkembang", "Bisnis")
  price       Int        // Monthly price in Rupiah
  periodDays  Int        @default(30)
  isActive    Boolean    @default(true)
  features    Json       // Array of feature strings
  createdAt   DateTime   @default(now())

  @@index([tier])
}

model CertificateTemplate {
  id              String   @id @default(cuid())
  userId          String   @unique
  name            String   @default("Custom Template")

  // Header Content
  title           String   @default("TOEFL ITP Simulation")
  subtitle        String   @default("Certificate of Completion")

  // Logo
  showLogo        Boolean  @default(true)
  logoUrl         String?

  // Signature
  signatureText   String   @default("Authorized Signature")

  // Footer
  footerText      String?

  // Validity
  validityDays    Int?     @default(365)  // Certificate validity in days (null = permanent)

  // Background Image
  backgroundImage String?

  // Layout
  fontFamily      String   @default("Inter")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MicrositeSettings {
  id              String   @id @default(cuid())
  userId          String   @unique

  // Header
  customHeaderHtml String?  // Custom HTML for header (BUSINESS)
  showDefaultHeader Boolean @default(true)

  // Footer
  customFooterHtml String?  // Custom HTML for footer (BUSINESS)
  showDefaultFooter Boolean @default(true)
  footerText        String? // Simple text footer

  // Branding
  removeLynkLogo   Boolean @default(false) // BUSINESS only
  showPoweredBy    Boolean @default(true)

  // Theme customization
  themeMode        String   @default("light") // "light", "dark", "auto"
  primaryColor     String   @default("#3b82f6") // PRO+
  secondaryColor   String?  // BUSINESS only
  accentColor       String?  // BUSINESS only
  fontFamily        String   @default("Inter") // BUSINESS only
  customCss         String?  // BUSINESS only - custom CSS override

  // Social links
  socialInstagram  String?
  socialFacebook   String?
  socialTwitter    String?
  socialYoutube    String?
  socialTiktok     String?
  socialLinkedin   String?

  // Contact info
  contactEmail     String?
  contactPhone     String?
  contactAddress   String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum PromoType {
  PERCENTAGE
  FIXED
}

enum PromoStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  USED_UP
}

model PromoCode {
  id            String      @id @default(cuid())
  userId        String
  code          String      @unique
  type          PromoType   @default(PERCENTAGE)
  value         Int         // percentage (0-100) or fixed amount in Rupiah
  minPurchase   Int         @default(0) // minimum purchase amount to apply
  maxDiscount   Int?        // maximum discount amount (for percentage type)
  usageLimit    Int?        // total uses allowed (null = unlimited)
  usageCount    Int         @default(0) // current usage count
  startDate     DateTime    @default(now())
  endDate       DateTime?   // null = no expiry
  status        PromoStatus @default(ACTIVE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  redemptions   PromoRedemption[]

  @@index([userId])
  @@index([code])
  @@index([status])
}

model PromoRedemption {
  id          String    @id @default(cuid())
  promoId     String
  orderId     String
  userId      String    // buyer who used the code
  discount    Int       // actual discount amount applied
  usedAt      DateTime  @default(now())

  promo PromoCode @relation(fields: [promoId], references: [id], onDelete: Cascade)

  @@index([promoId])
  @@index([userId])
}

// ============ CRM MODELS ============

model Customer {
  id            String    @id @default(cuid())
  ownerUserId   String    // seller who owns this customer
  buyerName     String
  buyerEmail    String    @unique
  buyerPhone    String?
  buyerAddress  String?
  totalPurchases Int     @default(0)
  totalSpent    Int       @default(0)
  lastPurchaseAt DateTime?
  notes         String?
  tags          String?   // comma-separated tags
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  ownerUser User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@index([ownerUserId])
  @@index([buyerEmail])
  @@index([createdAt])
  @@index([ownerUserId, createdAt])
}

// ============ API & WEBHOOK MODELS ============

model ApiKey {
  id            String    @id @default(cuid())
  userId        String    @unique
  key           String    @unique // hashed key for verification
  keyPrefix     String    // first 8 chars for display
  name          String    // e.g., "Production", "Development"
  permissions   Json      // array of permission strings
  isActive      Boolean   @default(true)
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([key])
}

model WebhookEndpoint {
  id           String    @id @default(cuid())
  userId       String
  url          String
  events       Json      // array of event types: ["order.completed", "order.refunded", "withdrawal.completed"]
  secret       String?   // for signature verification
  isActive     Boolean   @default(true)
  lastTriggered DateTime?
  failureCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  deliveries WebhookDelivery[]

  @@index([userId])
  @@index([isActive])
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  webhookId   String
  event       String   // event type
  payload     Json     // sent payload
  response    Json?    // response from endpoint
  statusCode  Int?
  success     Boolean  @default(false)
  error       String?
  deliveredAt DateTime @default(now())

  webhook WebhookEndpoint @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([deliveredAt])
}

// ============ ANALYTICS MODELS ============

model ProductView {
  id          String   @id @default(cuid())
  productId   String
  viewerIp    String?
  userAgent   String?
  referrer    String?
  viewedAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([viewedAt])
}

model EmailCampaign {
  id            String    @id @default(cuid())
  userId        String
  name          String
  subject       String
  template      String?   // HTML template
  sentCount     Int       @default(0)
  deliveredCount Int      @default(0)
  openCount     Int       @default(0)
  clickCount    Int       @default(0)
  status        String    @default("DRAFT") // DRAFT, SCHEDULED, SENDING, SENT
  scheduledAt   DateTime?
  sentAt        DateTime?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([sentAt])
}

// ============ SUPPORT MODELS ============

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model SupportTicket {
  id              String           @id @default(cuid())
  userId          String
  subject         String
  message         String           // Initial message from user
  responseMessage String?          // Response from admin/support
  status          TicketStatus     @default(OPEN)
  priority        TicketPriority   @default(NORMAL)
  category        String?          // BUG, FEATURE, BILLING, GENERAL, etc.
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([category])
}
