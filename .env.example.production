# ==============================================
# TOEFL Lynk - Environment Variables (Production)
# ==============================================

# ==============================================
# Aplikasi Dasar
# ==============================================
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://toefllynk.com
NEXT_PUBLIC_BASE_URL=https://toefllynk.com

# ==============================================
# Database
# ==============================================
DATABASE_URL="postgresql://user:password@host:5432/toefllynk?schema=public"

# ==============================================
# Autentikasi & Keamanan
# ==============================================
# Wajib: Minimal 32 karakter, generate dengan: openssl rand -base64 32
JWT_SECRET="YOUR-UNIQUE-SECRET-KEY-AT-LEAST-32-CHARS"

# ==============================================
# Redis (Cache & Session) - Disarankan untuk production
# ==============================================
REDIS_URL=redis://localhost:6379
# REDIS_TLS=true

# ==============================================
# Midtrans (Payment Gateway) - Production
# ==============================================
# Set ke true untuk menggunakan environment production Midtrans
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=true
MIDTRANS_SERVER_KEY="Mid-server-XXXXXXX"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="Mid-client-XXXXXXX"

# ==============================================
# Email
# ==============================================
EMAIL_PROVIDER=resend

# Resend (recommended for production)
RESEND_API_KEY=re_xxxxxxxxxx
RESEND_FROM="TOEFL Lynk <noreply@toefllynk.com>"

# Nodemailer (alternative)
# EMAIL_PROVIDER=nodemailer
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="465"
# SMTP_USER="your-email@example.com"
# SMTP_PASS="your-smtp-password"
# SMTP_FROM="TOEFL Lynk <noreply@toefllynk.com>"

# ==============================================
# Storage - Production (Gunakan cloud storage)
# ==============================================
STORAGE_PROVIDER=cloudflare-r2

# Cloudflare R2 (recommended)
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-key
CLOUDFLARE_R2_BUCKET=toefllynk
CLOUDFLARE_R2_PUBLIC_URL=https://your-r2-public-url.com

# Cloudinary (alternative)
# STORAGE_PROVIDER=cloudinary
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret
# CLOUDINARY_FOLDER=toefllynk

# ==============================================
# Monitoring
# ==============================================
SENTRY_DSN=https://example@host.ingest.sentry.io/xxxxx
SENTRY_ENVIRONMENT=production

# ==============================================
# Domain (Custom Domain - BUSINESS tier)
# ==============================================
# NEXT_PUBLIC_CUSTOM_DOMAIN_VERIFICATION_TOKEN=your-verification-token